# Copy this file to ".env" and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
#
# Both keys below are SAFE to expose in the browser. The anon key's power is
# limited by Row Level Security (see supabase/schema.sql). Never put the
# "service_role" / "secret" key here — that one bypasses security.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
